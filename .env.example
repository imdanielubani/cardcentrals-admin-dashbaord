# ──────────────────────────────────────────────────────────────────────────────
# Cardcentrals Admin Dashboard — environment template
#
# Copy to `.env` (or `.env.local`) and fill in real values. Never commit `.env`.
# Vite only exposes variables prefixed with `VITE_` to client code; everything
# else is server-build-only and won't reach the browser.
# ──────────────────────────────────────────────────────────────────────────────

# Public URL of the cardcentrals-backend API (must include /api/v1 suffix).
# Read by src/lib/api.ts and src/constants/api.constants.ts at build time.
# Local dev:    http://localhost:3000/api/v1
# Production:   https://api.cardcentrals.com/api/v1
VITE_API_URL=https://api.cardcentrals.com/api/v1
